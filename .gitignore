# Keep main.pdf for quick preview but ignore section-level PDFs
latex/sections/*.pdf

# ============================================================
# Data — opt-in policy
# ============================================================
# Never commit raw LLM responses (large, potentially sensitive to API TOS)
data/raw/llm_responses/*.jsonl
data/raw/llm_responses/*.parquet
# Keep synthetic examples but not real runs
!data/raw/llm_responses/.gitkeep

# Large processed data — commit only small reference samples
data/processed/*_large.parquet

